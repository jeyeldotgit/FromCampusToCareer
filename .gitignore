# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
.env/

# =============================================================================
# Environment and secrets
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Python cache and bytecode
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# =============================================================================
# Rye (dependency manager)
# =============================================================================
# Keep pyproject.toml and requirements.lock — they are committed
# Only ignore generated or local-only Rye artifacts
.python-version

# =============================================================================
# Testing and coverage
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log
pytest.ini.bak

# =============================================================================
# Linting and formatting
# =============================================================================
.ruff_cache/
.mypy_cache/

# =============================================================================
# Data files — raw source payloads and large processed datasets
# These are large binary/csv files that belong in cloud storage or DVC,
# not in git history.
# =============================================================================
data/raw/
data/processed/
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# =============================================================================
# Celery worker artifacts
# =============================================================================
celerybeat-schedule
celerybeat.pid
*.db

# =============================================================================
# Logs and runtime output
# =============================================================================
logs/
*.log
*.log.*

# =============================================================================
# Build and distribution artifacts
# =============================================================================
dist/
build/
*.egg-info/
*.egg
.eggs/
site/

# =============================================================================
# IDE and editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS artifacts
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
