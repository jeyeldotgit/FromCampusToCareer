# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fctc

# Security
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — comma-separated allowed origins (tighten this in production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Worker / data paths
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed

# spaCy model (download with: python -m spacy download en_core_web_sm)
SPACY_MODEL=en_core_web_sm
